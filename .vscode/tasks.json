{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Garden Master: Run Dev Server",
      "type": "shell",
      "command": "tasklist /FI \"IMAGENAME eq node.exe\" | find /I \"node.exe\" >nul 2>&1 && echo Dev server already running || npm run dev",
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*next dev.*$",
            "endsPattern": "^.*Ready in.*$"
          }
        }
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "devServer"
      }
    },
    {
      "label": "🚀 Deploy: Build + Commit + Push + Firebase",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}\\deploy.ps1"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
